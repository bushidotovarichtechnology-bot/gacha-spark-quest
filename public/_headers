# Long cache for hashed/static assets (JS/CSS/images bundled by Vite)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static images & fonts in /public (filenames are stable)
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=2592000
/*.mp4
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — short cache so deploys propagate quickly
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate
